            "body": { "mode": "raw", "raw": "{\n  \"categoryId\": \"cat_plumber\",\n  \"subServiceId\": \"sub_pl_leak\",\n  \"dateTime\": \"2026-07-20T10:00:00Z\",\n  \"timeSlot\": \"10:00 AM - 12:00 PM\",\n  \"address\": \"H.No 124, Sector 15, Gurugram\",\n  \"coupon\": \"SGSAVE30\",\n  \"paymentMethod\": \"UPI\"\n}" },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Get Customer Bookings List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["bookings"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "Cancel booking request",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/bk_1784387265906/cancel", "host": ["{{baseUrl}}"], "path": ["bookings", "bk_1784387265906", "cancel"] }
          }
        },
        {
          "name": "Reschedule booking time slot",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"dateTime\": \"2026-07-21T14:00:00Z\",\n  \"timeSlot\": \"02:00 PM - 04:00 PM\"\n}" },
            "url": { "raw": "{{baseUrl}}/bookings/bk_1784387265906/reschedule", "host": ["{{baseUrl}}"], "path": ["bookings", "bk_1784387265906", "reschedule"] }
          }
        },
