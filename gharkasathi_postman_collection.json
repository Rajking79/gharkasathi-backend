            "body": { "mode": "raw", "raw": "{\n  \"code\": \"SGSAVE30\",\n  \"amount\": 399\n}" },
            "url": { "raw": "{{baseUrl}}/coupon/validate", "host": ["{{baseUrl}}"], "path": ["coupon", "validate"] }
          }
