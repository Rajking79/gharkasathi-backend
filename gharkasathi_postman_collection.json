{
  "info": {
    "_postman_id": "gharkasathi-production-live-2026-v3",
    "name": "Ghar Ka Sathi Production APIs",
    "description": "Complete 75+ API Suite for Ghar Ka Sathi pointing to Live Render Production URL via {{baseUrl}} variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://gharkasathi-backend-neuj.onrender.com/api/v1",
      "type": "string"
    },
    {
      "key": "user_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "provider_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "app",
      "item": [
        {
          "name": "version",
          "item": [
            {
              "name": "Check App Version",
              "request": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/app/version", "host": ["{{baseUrl}}"], "path": ["app", "version"] }
              }
            }
          ]
        },
        {
          "name": "maintenance",
          "item": [
            {
              "name": "Maintenance Check",
              "request": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/app/maintenance", "host": ["{{baseUrl}}"], "path": ["app", "maintenance"] }
              }
            }
          ]
        },
        {
          "name": "config",
          "item": [
            {
              "name": "App Configuration parameters",
              "request": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/app/config", "host": ["{{baseUrl}}"], "path": ["app", "config"] }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "auth",
      "item": [
        {
          "name": "send-otp",
          "item": [
            {
              "name": "Send OTP SMS",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9876543210\"\n}" },
                "url": { "raw": "{{baseUrl}}/auth/send-otp", "host": ["{{baseUrl}}"], "path": ["auth", "send-otp"] }
              }
            }
          ]
        },
        {
          "name": "verify-otp",
          "item": [
            {
              "name": "Verify OTP & Generate JWT",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"123456\",\n  \"role\": \"user\"\n}" },
                "url": { "raw": "{{baseUrl}}/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["auth", "verify-otp"] }
              }
            }
          ]
        },
        {
          "name": "refresh",
          "item": [
            {
              "name": "Refresh Access Token",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"refresh_demo_123\"\n}" },
                "url": { "raw": "{{baseUrl}}/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["auth", "refresh-token"] }
              }
            }
          ]
        },
        {
          "name": "logout",
          "item": [
            {
              "name": "Logout from session",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
                "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
              }
            }
          ]
        },
        {
          "name": "account",
          "item": [
            {
              "name": "Delete Account Permanently",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
                "url": { "raw": "{{baseUrl}}/auth/account", "host": ["{{baseUrl}}"], "path": ["auth", "account"] }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "customer",
      "item": [
        {
          "name": "profile",
          "item": [
            {
              "name": "Get Profile details",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
                "url": { "raw": "{{baseUrl}}/customer/profile", "host": ["{{baseUrl}}"], "path": ["customer", "profile"] }
              }
            },
            {
              "name": "Create Profile details",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{user_token}}" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"gender\": \"Male\",\n  \"dob\": \"1992-05-15\"\n}" },
                "url": { "raw": "{{baseUrl}}/customer/profile", "host": ["{{baseUrl}}"], "path": ["customer", "profile"] }
              }
            },
            {
              "name": "Update Profile details",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{user_token}}" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Updated\"\n}" },
                "url": { "raw": "{{baseUrl}}/customer/profile", "host": ["{{baseUrl}}"], "path": ["customer", "profile"] }
              }
            },
            {
              "name": "Upload Profile Avatar Image",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
                "body": {
                  "mode": "formdata",
                  "formdata": [{ "key": "avatar", "type": "file", "src": [] }]
                },
                "url": { "raw": "{{baseUrl}}/customer/profile/avatar", "host": ["{{baseUrl}}"], "path": ["customer", "profile", "avatar"] }
              }
            }
          ]
        },
        {
          "name": "address",
          "item": [
            {
              "name": "Get All Address Book",
              "request": {
                "method": "GET",
