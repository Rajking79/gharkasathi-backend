            ],
            "body": { "mode": "raw", "raw": "{\n  \"cost\": 150,\n  \"reason\": \"Extra pipe labor\"\n}" },
            "url": { "raw": "{{baseUrl}}/bookings/bk_1784387265906/extra-work", "host": ["{{baseUrl}}"], "path": ["bookings", "bk_1784387265906", "extra-work"] }
          }
        },
        {
          "name": "Approve Extra Work",
          "request": {
            "method": "POST",
