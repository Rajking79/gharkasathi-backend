{
  "info": {
    "_postman_id": "gharkasathi-customer-app-only-2026",
    "name": "Ghar Ka Sathi Customer App APIs",
    "description": "Strictly Customer App (GharKaSathiUserApp) API Collection. Every endpoint maps to a Customer App screen.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://gharkasathi-backend-neuj.onrender.com/api/v1",
      "type": "string"
    },
    {
      "key": "user_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "App Launch & Initialization",
      "item": [
        {
          "name": "Healthcheck",
          "request": {
            "method": "GET",
            "url": { "raw": "https://gharkasathi-backend-neuj.onrender.com/health", "protocol": "https", "host": ["gharkasathi-backend-neuj", "onrender", "com"], "path": ["health"] }
          }
        },
        {
          "name": "Check App Version",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/app/version", "host": ["{{baseUrl}}"], "path": ["app", "version"] }
          }
        },
        {
          "name": "Check Maintenance Mode",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/app/maintenance", "host": ["{{baseUrl}}"], "path": ["app", "maintenance"] }
          }
        },
        {
          "name": "Get App Configuration",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/app/config", "host": ["{{baseUrl}}"], "path": ["app", "config"] }
          }
        }
      ]
    },
    {
      "name": "Customer Auth",
      "item": [
        {
          "name": "Send Customer Mobile OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9876543210\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/send-otp", "host": ["{{baseUrl}}"], "path": ["auth", "send-otp"] }
          }
        },
        {
          "name": "Verify OTP & Get Customer JWT Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"123456\",\n  \"role\": \"user\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["auth", "verify-otp"] }
          }
        },
        {
          "name": "Refresh Customer Access Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"refresh_demo_123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["auth", "refresh-token"] }
          }
        },
        {
          "name": "Logout Customer Session",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Delete Customer Account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/account", "host": ["{{baseUrl}}"], "path": ["auth", "account"] }
          }
        }
      ]
    },
    {
      "name": "Customer Profile & Addresses",
      "item": [
        {
          "name": "Get Customer Profile Details",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{baseUrl}}/customer/profile", "host": ["{{baseUrl}}"], "path": ["customer", "profile"] }
          }
        },
        {
          "name": "Create / Complete Customer Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Customer\",\n  \"email\": \"john@example.com\",\n  \"gender\": \"Male\",\n  \"dob\": \"1992-05-15\"\n}" },
            "url": { "raw": "{{baseUrl}}/customer/profile", "host": ["{{baseUrl}}"], "path": ["customer", "profile"] }
          }
        },
        {
          "name": "Update Customer Profile Info",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Updated\"\n}" },
            "url": { "raw": "{{baseUrl}}/customer/profile", "host": ["{{baseUrl}}"], "path": ["customer", "profile"] }
          }
        },
        {
          "name": "Upload Customer Avatar Image",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "avatar", "type": "file", "src": [] }]
            },
            "url": { "raw": "{{baseUrl}}/customer/profile/avatar", "host": ["{{baseUrl}}"], "path": ["customer", "profile", "avatar"] }
          }
        },
        {
          "name": "Get Saved Address Book",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{baseUrl}}/address", "host": ["{{baseUrl}}"], "path": ["address"] }
          }
        },
        {
          "name": "Add New Address to Book",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"addressLine\": \"Flat 302, Sector 15\",\n  \"city\": \"Gurugram\",\n  \"state\": \"Haryana\",\n  \"pincode\": \"122001\",\n  \"isDefault\": true\n}" },
            "url": { "raw": "{{baseUrl}}/address", "host": ["{{baseUrl}}"], "path": ["address"] }
          }
        }
      ]
    },
    {
      "name": "Home Dashboard Feed",
      "item": [
        {
          "name": "Get Customer Home Dashboard Feed",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/home", "host": ["{{baseUrl}}"], "path": ["home"] }
          }
        },
        {
          "name": "Get Promotional Banners",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/home/banners", "host": ["{{baseUrl}}"], "path": ["home", "banners"] }
          }
        },
        {
          "name": "Get Featured Top Services",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/home/featured", "host": ["{{baseUrl}}"], "path": ["home", "featured"] }
          }
        }
      ]
    },
    {
      "name": "Categories & Services Search",
      "item": [
        {
          "name": "Get All Service Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Get Category & Sub-Services Details",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/categories/cat_plumber", "host": ["{{baseUrl}}"], "path": ["categories", "cat_plumber"] }
          }
        },
        {
          "name": "Search Services by Keyword",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/categories/search/services?query=tap", "host": ["{{baseUrl}}"], "path": ["categories", "search", "services"], "query": [{ "key": "query", "value": "tap" }] }
          }
        }
      ]
    },
    {
      "name": "Coupons & Offers",
      "item": [
        {
          "name": "Get Available Promo Coupons List",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/coupon", "host": ["{{baseUrl}}"], "path": ["coupon"] }
          }
        },
        {
          "name": "Validate & Apply Promo Coupon",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"SGSAVE30\",\n  \"amount\": 399\n}" },
            "url": { "raw": "{{baseUrl}}/coupon/validate", "host": ["{{baseUrl}}"], "path": ["coupon", "validate"] }
          }
        }
      ]
    },
    {
      "name": "Customer Bookings",
      "item": [
        {
          "name": "Create New Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"categoryId\": \"cat_plumber\",\n  \"subServiceId\": \"sub_pl_leak\",\n  \"dateTime\": \"2026-07-20T10:00:00Z\",\n  \"timeSlot\": \"10:00 AM - 12:00 PM\",\n  \"address\": \"H.No 124, Sector 15, Gurugram\",\n  \"coupon\": \"SGSAVE30\",\n  \"paymentMethod\": \"UPI\"\n}" },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Get Customer Bookings History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["bookings"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "Cancel Booking Request",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/bk_1784387265906/cancel", "host": ["{{baseUrl}}"], "path": ["bookings", "bk_1784387265906", "cancel"] }
          }
        },
        {
          "name": "Reschedule Booking Time Slot",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"dateTime\": \"2026-07-21T14:00:00Z\",\n  \"timeSlot\": \"02:00 PM - 04:00 PM\"\n}" },
            "url": { "raw": "{{baseUrl}}/bookings/bk_1784387265906/reschedule", "host": ["{{baseUrl}}"], "path": ["bookings", "bk_1784387265906", "reschedule"] }
          }
        },
        {
          "name": "Customer Approve Extra Work",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/bk_1784387265906/approve-extra", "host": ["{{baseUrl}}"], "path": ["bookings", "bk_1784387265906", "approve-extra"] }
          }
        },
        {
          "name": "Pay & Settle Booking Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/bk_1784387265906/pay", "host": ["{{baseUrl}}"], "path": ["bookings", "bk_1784387265906", "pay"] }
          }
        },
        {
          "name": "Submit Rating & Review Feedback",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"bookingId\": \"bk_1784387265906\",\n  \"stars\": 5,\n  \"comment\": \"Great service!\"\n}" },
            "url": { "raw": "{{baseUrl}}/review", "host": ["{{baseUrl}}"], "path": ["review"] }
          }
        }
      ]
    },
    {
      "name": "Customer Notifications & Support",
      "item": [
        {
          "name": "Get Customer Notifications List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{baseUrl}}/notifications", "host": ["{{baseUrl}}"], "path": ["notifications"] }
          }
        },
        {
          "name": "Create Support Ticket",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"subject\": \"Delay in expert arrival\",\n  \"message\": \"Expert has not arrived yet.\"\n}" },
            "url": { "raw": "{{baseUrl}}/support/tickets", "host": ["{{baseUrl}}"], "path": ["support", "tickets"] }
          }
        },
        {
          "name": "Trigger SOS Panic Safety Alert",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"latitude\": 28.4595,\n  \"longitude\": 77.0266\n}" },
            "url": { "raw": "{{baseUrl}}/support/sos", "host": ["{{baseUrl}}"], "path": ["support", "sos"] }
          }
        }
      ]
    }
  ]
}
