          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/categories/search/services?query=tap", "host": ["{{baseUrl}}"], "path": ["categories", "search", "services"], "query": [{ "key": "query", "value": "tap" }] }
